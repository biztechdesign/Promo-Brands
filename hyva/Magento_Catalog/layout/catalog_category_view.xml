<?xml version="1.0"?>
<!--
    Layout override for a product-listing category page.
    Place at:
      app/design/frontend/PromoBrand/hyva/Magento_Catalog/layout/catalog_category_view.xml

    Removes the default Hyvä toolbar + product list and injects a single
    view.phtml that owns the full sidebar + grid layout.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <update handle="catalog_category_view_type_default"/>

    <body>
        <!-- Remove default product list, toolbar, and category intro blocks -->
        <referenceBlock name="category.products"        remove="true"/>
        <referenceBlock name="category.view.container"  remove="true"/>

        <referenceContainer name="content">
            <block class="Magento\Catalog\Block\Category\View"
                   name="category.product.listing"
                   template="Magento_Catalog::category/view.phtml"
                   cacheable="false">
                <arguments>
                    <argument name="view_model"
                              xsi:type="object">PromoBrand\Theme\ViewModel\CategoryListing</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>

</page>
