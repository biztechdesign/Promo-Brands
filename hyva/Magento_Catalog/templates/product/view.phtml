<?php
/**
 * Hyvä-compatible product detail page template (PDP).
 *
 * Place at:
 *   app/design/frontend/PromoBrand/hyva/Magento_Catalog/templates/product/view.phtml
 *
 * Wired up via:
 *   Magento_Catalog/layout/catalog_product_view.xml
 *
 * @var \Magento\Catalog\Block\Product\View           $block
 * @var \Magento\Framework\Escaper                    $escaper
 * @var \Hyva\Theme\Model\ViewModelRegistry           $viewModels
 */

/** @var \Hyva\Theme\ViewModel\ProductPage $productViewModel */
$productViewModel = $viewModels->require(\Hyva\Theme\ViewModel\ProductPage::class);

/** @var \Hyva\Theme\ViewModel\ProductPrice $priceViewModel */
$priceViewModel = $viewModels->require(\Hyva\Theme\ViewModel\ProductPrice::class);

/** @var \Hyva\Theme\ViewModel\ProductImages $productImages */
$productImages = $viewModels->require(\Hyva\Theme\ViewModel\ProductImages::class);

$product     = $block->getProduct();
$productName = $escaper->escapeHtml($product->getName());
$productSku  = $escaper->escapeHtml($product->getSku());
$productUrl  = $escaper->escapeUrl($product->getProductUrl());

// ── Price ──────────────────────────────────────────────────────────────────
$finalPrice   = $priceViewModel->getPriceValue(
    $product,
    \Magento\Catalog\Pricing\Price\FinalPrice::PRICE_CODE
);
$regularPrice = $priceViewModel->getPriceValue(
    $product,
    \Magento\Catalog\Pricing\Price\RegularPrice::PRICE_CODE
);
$isOnSale = $regularPrice && $finalPrice < $regularPrice;

// ── Custom B2B attributes ──────────────────────────────────────────────────
$moq         = (int) ($product->getData('moq') ?: 50);
$isNew       = (bool) $product->getData('is_new');
$isEco       = (bool) $product->getData('is_eco');
$badge       = '';
$badgeClass  = '';
if ($isEco) {
    $badge = __('Eco'); $badgeClass = 'bg-black text-paper';
} elseif ($isNew) {
    $badge = __('New'); $badgeClass = 'bg-accent text-paper';
} elseif ($isOnSale) {
    $badge = __('Sale'); $badgeClass = 'bg-ink text-paper';
}

// Short description (sanitised — Magento stores it as HTML)
$shortDescription = $productViewModel->getShortDescription($product);

// Full description
$description = $product->getData('description')
    ? $productViewModel->getDescription($product)
    : '';

// Colour options from a multiselect / swatch attribute
$colourOptions = [];
try {
    $colourAttr = $product->getResource()->getAttribute('colour_options');
    if ($colourAttr) {
        foreach ($colourAttr->getSource()->getAllOptions(false) as $opt) {
            $colourOptions[] = [
                'label' => $escaper->escapeHtmlAttr($opt['label']),
                'value' => $escaper->escapeHtmlAttr($opt['value']),
                'hex'   => $escaper->escapeHtmlAttr($opt['swatch_value'] ?? '#363A36'),
            ];
        }
    }
} catch (\Exception $e) {
    // Attribute not present — swatches section will be skipped
}

// Branding methods from a multiselect attribute
$brandingMethods = [];
try {
    $methodAttr = $product->getResource()->getAttribute('branding_methods');
    if ($methodAttr) {
        foreach ($methodAttr->getSource()->getAllOptions(false) as $opt) {
            $brandingMethods[] = [
                'label' => $escaper->escapeHtmlAttr($opt['label']),
                'value' => $escaper->escapeHtmlAttr($opt['value']),
            ];
        }
    }
} catch (\Exception $e) {
    // Attribute not present — branding section will be skipped
}

// ── Gallery images ─────────────────────────────────────────────────────────
$galleryImages = [];
$mediaGallery  = $product->getMediaGalleryImages();
if ($mediaGallery) {
    foreach ($mediaGallery as $image) {
        $galleryImages[] = [
            'src'   => $escaper->escapeUrl($image->getUrl()),
            'thumb' => $escaper->escapeUrl($image->getData('small_image_url') ?: $image->getUrl()),
            'alt'   => $escaper->escapeHtmlAttr($image->getData('label') ?: $product->getName()),
        ];
    }
}
// Fallback: use the base product image
if (empty($galleryImages)) {
    $baseUrl = $block->getImage($product, 'product_base_image')->getImageUrl();
    if ($baseUrl) {
        $galleryImages[] = [
            'src'   => $escaper->escapeUrl($baseUrl),
            'thumb' => $escaper->escapeUrl($baseUrl),
            'alt'   => $escaper->escapeHtmlAttr($product->getName()),
        ];
    }
}
$galleryJson = /* @noEscape */ json_encode($galleryImages);

// ── Stock status ────────────────────────────────────────────────────────────
$stockItem  = $product->getExtensionAttributes()->getStockItem();
$isInStock  = $stockItem ? $stockItem->getIsInStock() : true;

// ── Additional attributes for the specs table ───────────────────────────────
$specAttributes = [
    'capacity'       => __('Capacity'),
    'material'       => __('Material'),
    'dimensions'     => __('Dimensions'),
    'weight'         => __('Weight'),
    'finish'         => __('Finish'),
    'keep_cold_hrs'  => __('Keeps Cold'),
    'keep_hot_hrs'   => __('Keeps Hot'),
    'bpa_free'       => __('BPA Free'),
    'dishwasher_safe'=> __('Dishwasher Safe'),
];
?>

<!-- =================== BREADCRUMB =================== -->
<nav class="bg-paper border-b border-line" aria-label="<?= $escaper->escapeHtmlAttr(__('Breadcrumb')) ?>">
    <div class="max-w-8xl mx-auto px-4 lg:px-8 py-3">
        <ol class="flex items-center gap-1.5 text-sm flex-wrap">
            <li><a href="<?= $escaper->escapeUrl($block->getUrl('')) ?>" class="text-stone hover:text-accent transition"><?= $escaper->escapeHtml(__('Home')) ?></a></li>
            <li class="text-stone/40" aria-hidden="true">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/></svg>
            </li>
            <?php
            $categoryCollection = $product->getCategoryCollection()->addAttributeToSelect('name')->addAttributeToSelect('url_key');
            $breadcrumbCategory = $categoryCollection->getFirstItem();
            if ($breadcrumbCategory && $breadcrumbCategory->getId()):
            ?>
                <li><a href="<?= $escaper->escapeUrl($breadcrumbCategory->getUrl()) ?>" class="text-stone hover:text-accent transition"><?= $escaper->escapeHtml($breadcrumbCategory->getName()) ?></a></li>
                <li class="text-stone/40" aria-hidden="true">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/></svg>
                </li>
            <?php endif; ?>
            <li class="text-ink font-medium" aria-current="page"><?= $productName ?></li>
        </ol>
    </div>
</nav>

