<?php
/**
 * Hyvä-compatible product list (card grid).
 *
 * Place at:
 *   app/design/frontend/PromoBrand/hyva/Magento_Catalog/templates/product/list.phtml
 *
 * Rendered as a child block of category/view.phtml.
 *
 * @var \Magento\Catalog\Block\Product\ListProduct $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Hyva\Theme\Model\ViewModelRegistry $viewModels
 */

/** @var \Magento\Catalog\Model\ResourceModel\Product\Collection $productCollection */
$productCollection = $block->getLoadedProductCollection();

/** @var \Hyva\Theme\ViewModel\ProductPrice $priceViewModel */
$priceViewModel = $viewModels->require(\Hyva\Theme\ViewModel\ProductPrice::class);
?>

<div id="product-grid"
     class="grid grid-cols-2 md:grid-cols-3 gap-4 sm:gap-5 lg:gap-6">

    <?php if ($productCollection->count()): ?>

        <?php foreach ($productCollection as $product): ?>
            <?php
            $productName  = $escaper->escapeHtml($product->getName());
            $productUrl   = $escaper->escapeUrl($product->getProductUrl());
            $imageUrl     = $block->getImage($product, 'category_page_grid')->getImageUrl();
            $imageUrl     = $imageUrl ? $escaper->escapeUrl($imageUrl) : '';

            // Badges: map product attributes to badge label/colour
            $badge = '';
            $badgeClass = '';
            if ($product->getData('is_new')) {
                $badge = __('New'); $badgeClass = 'bg-accent text-paper';
            } elseif ($product->getData('is_eco')) {
                $badge = __('Eco'); $badgeClass = 'bg-black text-paper';
            } elseif ($product->getSpecialPrice() && $product->getSpecialPrice() < $product->getPrice()) {
                $badge = __('Sale'); $badgeClass = 'bg-ink text-paper';
            }

            $fromPrice = $priceViewModel->getPriceValue($product, \Magento\Catalog\Pricing\Price\FinalPrice::PRICE_CODE);
            $moq = $product->getData('moq') ?: '50';
            $colours = $product->getData('colour_count') ?: '1';
            ?>

            <article class="product-card group">
                <a href="<?= $productUrl ?>"
                   class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">

                    <div class="relative aspect-square overflow-hidden bg-paper border border-line mb-4 flex items-center justify-center p-4">

                        <?php if ($imageUrl): ?>
                            <img src="<?= $imageUrl ?>"
                                 alt="<?= $escaper->escapeHtmlAttr($productName) ?>"
                                 loading="lazy"
                                 class="product-img w-full h-full object-contain"/>
                        <?php else: ?>
                            <div class="w-full h-full flex items-center justify-center bg-line/30">
                                <svg class="w-10 h-10 text-stone/30" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24" aria-hidden="true">
                                    <rect x="3" y="3" width="18" height="18" rx="1"/>
                                    <path d="m3 15 5-5 4 4 3-3 6 6" stroke-linecap="round" stroke-linejoin="round"/>
                                    <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" stroke="none"/>
                                </svg>
                            </div>
                        <?php endif; ?>

                        <?php if ($badge): ?>
                            <span class="absolute top-3 left-3 <?= $escaper->escapeHtmlAttr($badgeClass) ?> text-[10px] uppercase tracking-widest px-2 py-1">
                                <?= $escaper->escapeHtml($badge) ?>
                            </span>
                        <?php endif; ?>

                        <button class="absolute top-3 right-3 w-8 h-8 bg-paper border border-line hover:border-accent flex items-center justify-center transition"
                                aria-label="<?= $escaper->escapeHtmlAttr(__('Save %1', $productName)) ?>"
                                @click.prevent="$dispatch('add-to-wishlist', { productId: <?= (int) $product->getId() ?> })">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                            </svg>
                        </button>

                    </div>

                    <h2 class="text-base font-bold mb-1 truncate"><?= $productName ?></h2>

                    <p class="text-sm text-stone mb-2">
                        <?= $escaper->escapeHtml($product->getAttributeText('category_name') ?: __('Drinkware')) ?>
                        &middot;
                        <?= (int) $colours ?> <?= $escaper->escapeHtml(__('colour(s)')) ?>
                    </p>

                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-y-1">
                        <span class="text-sm">
                            <?= $escaper->escapeHtml(__('From')) ?>
                            <strong><?= $block->getCurrencySymbol() ?><?= number_format((float) $fromPrice, 2) ?></strong>
                            <span class="text-stone">/ MOQ <?= (int) $moq ?></span>
                        </span>
                        <span class="arrow-link text-sm font-bold text-accent group-hover:text-ink transition">
                            <?= $escaper->escapeHtml(__('Enquire')) ?>
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                            </svg>
                        </span>
                    </div>

                </a>
            </article>

        <?php endforeach; ?>

    <?php else: ?>

        <p class="col-span-full text-sm text-stone py-8">
            <?= $escaper->escapeHtml(__('No products found in this category.')) ?>
        </p>

    <?php endif; ?>

</div>
