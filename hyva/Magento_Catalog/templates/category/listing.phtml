<?php
/**
 * Hyvä-compatible category listing template for Promo Brand theme.
 *
 * Place at:
 *   app/design/frontend/PromoBrand/hyva/Magento_Catalog/templates/category/listing.phtml
 *
 * Requires custom Tailwind color tokens in web/tailwind/tailwind.config.js:
 *   ink: '#363A36'  paper: '#FFFFFF'  stone: '#6B6B6B'
 *   line: '#E5E5E5'  accent: '#EC1C51'
 *
 * Two-line clamp: Tailwind v3 ships line-clamp utilities natively.
 * Add to tailwind.config.js plugins array if using an older build:
 *   require('@tailwindcss/line-clamp')
 *
 * @var \Magento\Catalog\Block\Category\View $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Hyva\Theme\Model\ViewModelRegistry $viewModels
 */

/**
 * Fetch child categories of the current category.
 * Swap $childCategories for a ViewModel collection if you prefer to
 * avoid direct ObjectManager usage in production templates.
 */
$currentCategory = $block->getCurrentCategory();
$childCategories = $currentCategory
    ? $currentCategory->getChildrenCategories()
    : [];

$totalCount = is_countable($childCategories) ? count($childCategories) : iterator_count($childCategories);
?>

<!-- =================== PAGE HEADER: Title + Search =================== -->
<div class="bg-paper border-b border-line"
     x-data="categorySearch()"
     @category-search.window="filterCards($event.detail)">

    <div class="max-w-8xl mx-auto px-4 lg:px-8 py-8 lg:py-10
                flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">

        <h1 class="display text-2xl sm:text-3xl lg:text-4xl shrink-0">
            <?= $escaper->escapeHtml($currentCategory ? $currentCategory->getName() : __('Category')) ?>
        </h1>

        <!-- Search box -->
        <div class="relative w-full sm:w-72 lg:w-80">
            <label for="category-search" class="sr-only">
                <?= $escaper->escapeHtml(__('Search categories')) ?>
            </label>
            <input
                type="search"
                id="category-search"
                name="category_search"
                placeholder="<?= $escaper->escapeHtmlAttr(__('Search categories&hellip;')) ?>"
                autocomplete="off"
                x-model="query"
                @input.debounce.200ms="filter()"
                class="w-full border border-line pl-4 pr-10 py-3 text-base text-ink
                       placeholder:text-stone/60 focus:outline-none focus:border-ink transition"
            />
            <span class="absolute inset-y-0 right-0 w-10 flex items-center justify-center
                         text-stone pointer-events-none" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8"
                     viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="7"/>
                    <path d="m20 20-3.5-3.5" stroke-linecap="round"/>
                </svg>
            </span>
        </div>

    </div>
</div>

<!-- =================== CATEGORY GRID =================== -->
<div class="bg-paper"
     x-data="categoryListing()"
     x-init="init()"
     @category-search.window="filterByQuery($event.detail)">

    <div class="max-w-8xl mx-auto px-4 lg:px-8 py-10 lg:py-[70px]">

        <!-- Results count -->
        <p class="text-sm text-stone mb-6 lg:mb-8">
            <?= $escaper->escapeHtml(__('Showing')) ?>
            <strong class="text-ink" x-text="visibleCount"></strong>
            <?= $escaper->escapeHtml(__('categories')) ?>
        </p>

        <!-- Cards grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 lg:gap-8"
             :class="{ 'hidden': visibleCount === 0 }"
             id="category-grid">

            <?php if ($totalCount > 0): ?>

                <?php foreach ($childCategories as $category): ?>
                    <?php
                    $categoryName  = $escaper->escapeHtml($category->getName());
                    $categoryUrl   = $escaper->escapeUrl($category->getUrl());
                    $description   = $category->getDescription()
                        ? strip_tags($category->getDescription())
                        : '';
                    $imgUrl        = $category->getImageUrl()
                        ? $escaper->escapeUrl($category->getImageUrl())
                        : '';
                    ?>

                    <article class="category-card group border border-line"
                             data-name="<?= $escaper->escapeHtmlAttr(strtolower($categoryName)) ?>">
                        <a href="<?= $categoryUrl ?>"
                           class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">

                            <!-- Category image -->
                            <div class="overflow-hidden aspect-[4/3] bg-stone/5">
                                <?php if ($imgUrl): ?>
                                    <img
                                        src="<?= $imgUrl ?>"
                                        alt="<?= $escaper->escapeHtmlAttr($categoryName . ' ' . __('category')) ?>"
                                        loading="lazy"
                                        class="w-full h-full object-cover transition duration-500 group-hover:scale-105"
                                    />
                                <?php else: ?>
                                    <!-- Placeholder when no image is set -->
                                    <div class="w-full h-full flex items-center justify-center bg-line/40">
                                        <svg class="w-12 h-12 text-stone/30" fill="none" stroke="currentColor"
                                             stroke-width="1.2" viewBox="0 0 24 24" aria-hidden="true">
                                            <rect x="3" y="3" width="18" height="18" rx="1"/>
                                            <path d="m3 15 5-5 4 4 3-3 6 6" stroke-linecap="round" stroke-linejoin="round"/>
                                            <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" stroke="none"/>
                                        </svg>
                                    </div>
                                <?php endif; ?>
                            </div>

                            <!-- Card content -->
                            <div class="p-5 sm:p-6">
                                <h2 class="text-lg font-bold text-ink mb-2">
                                    <?= $categoryName ?>
                                </h2>

                                <?php if ($description): ?>
                                    <p class="text-sm text-stone leading-relaxed line-clamp-2 mb-4">
                                        <?= $escaper->escapeHtml($description) ?>
                                    </p>
                                <?php else: ?>
                                    <p class="text-sm text-stone leading-relaxed line-clamp-2 mb-4">
                                        <?= $escaper->escapeHtml(__(
                                            'Browse our full range of %1 branded merchandise.',
                                            $categoryName
                                        )) ?>
                                    </p>
                                <?php endif; ?>

                                <span class="arrow-link text-sm font-bold text-accent
                                             group-hover:text-ink transition"
                                      aria-label="<?= $escaper->escapeHtmlAttr(
                                          __('Read more about %1', $categoryName)
                                      ) ?>">
                                    <?= $escaper->escapeHtml(__('Read More')) ?>
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                         stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                                    </svg>
                                </span>
                            </div>

                        </a>
                    </article>

                <?php endforeach; ?>

            <?php else: ?>

                <!-- Static fallback if no child categories exist in Magento -->
                <p class="col-span-full text-sm text-stone py-4">
                    <?= $escaper->escapeHtml(__('No sub-categories found.')) ?>
                </p>

            <?php endif; ?>

        </div>

        <!-- Empty-state: shown when search finds nothing -->
        <div x-show="visibleCount === 0"
             x-cloak
             class="py-20 text-center">
            <svg class="w-12 h-12 mx-auto text-stone/30 mb-4" fill="none" stroke="currentColor"
                 stroke-width="1.2" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="11" cy="11" r="7"/>
                <path d="m20 20-3.5-3.5" stroke-linecap="round"/>
            </svg>
            <p class="text-lg font-bold mb-1">
                <?= $escaper->escapeHtml(__('No categories found')) ?>
            </p>
            <p class="text-sm text-stone">
                <?= $escaper->escapeHtml(__('Try a different search term.')) ?>
            </p>
        </div>

    </div>
</div>

<script>
/**
 * Alpine.js component for the category search input.
 * Dispatches a custom event consumed by the listing component.
 */
function categorySearch() {
    return {
        query: '',
        filter() {
            window.dispatchEvent(
                new CustomEvent('category-search', { detail: this.query.trim().toLowerCase() })
            );
        }
    };
}

/**
 * Alpine.js component for the category card grid.
 * Listens for search events and shows/hides cards accordingly.
 */
function categoryListing() {
    return {
        visibleCount: <?= (int) $totalCount ?>,
        totalCount:   <?= (int) $totalCount ?>,

        init() {
            this.visibleCount = this.totalCount;
        },

        filterByQuery(query) {
            const cards = document.querySelectorAll('.category-card');
            let visible = 0;
            cards.forEach(card => {
                const name    = card.dataset.name || '';
                const matches = !query || name.includes(query);
                card.style.display = matches ? '' : 'none';
                if (matches) visible++;
            });
            this.visibleCount = visible;
        }
    };
}
</script>
