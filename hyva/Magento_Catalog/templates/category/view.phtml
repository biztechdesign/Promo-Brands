                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/>
                    </svg>
                </li>
                <li>
                    <a href="<?= $crumb['url'] ?>" class="text-stone hover:text-accent transition">
                        <?= $crumb['name'] ?>
                    </a>
                </li>
            <?php endforeach; ?>

            <li class="text-stone/40" aria-hidden="true">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/>
                </svg>
            </li>
            <li class="text-ink font-medium" aria-current="page"><?= $categoryName ?></li>
        </ol>
    </div>
</nav>

