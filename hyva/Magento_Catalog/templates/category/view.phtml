                                      aria-current="page"><?= (int) $p ?></span>
                            <?php elseif ($p === 1 || $p === $lastPage || abs($p - $currentPage) <= 1): ?>
                                <a href="?p=<?= (int) $p ?>"
                                   class="w-10 h-10 flex items-center justify-center border border-line hover:border-ink hover:bg-line/30 transition text-sm">
                                    <?= (int) $p ?>
                                </a>
                            <?php elseif (abs($p - $currentPage) === 2): ?>
                                <span class="w-10 h-10 flex items-center justify-center text-stone text-sm select-none">&hellip;</span>
                            <?php endif; ?>
                        <?php endfor; ?>

                        <?php if ($currentPage < $lastPage): ?>
                            <a href="?p=<?= (int)($currentPage + 1) ?>"
                               class="w-10 h-10 flex items-center justify-center border border-line hover:border-ink transition text-stone"
