<?php
/**
 * Hyvä-compatible product-listing category page.
 *
 * Place at:
 *   app/design/frontend/PromoBrand/hyva/Magento_Catalog/templates/category/view.phtml
 *
 * Renders: breadcrumb, page header, sidebar filters, toolbar, product grid, pagination.
 *
 * @var \Magento\Catalog\Block\Category\View $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Hyva\Theme\Model\ViewModelRegistry $viewModels
 */

$category = $block->getCurrentCategory();
$categoryName = $category ? $escaper->escapeHtml($category->getName()) : '';
$categoryDesc = $category ? strip_tags($category->getDescription()) : '';

/** @var \Magento\Catalog\Model\ResourceModel\Product\Collection $products */
$productCollection = $category
    ? $category->getProductCollection()
        ->addAttributeToSelect(['name', 'url_key', 'price', 'small_image', 'thumbnail'])
        ->setPageSize(12)
        ->setCurPage(max(1, (int) ($block->getRequest()->getParam('p', 1))))
    : null;

$totalCount = $productCollection ? $productCollection->getSize() : 0;
$currentPage = $productCollection ? $productCollection->getCurPage() : 1;
$lastPage    = $productCollection ? $productCollection->getLastPageNumber() : 1;

// Breadcrumb: collect parent categories
$breadcrumbs = [];
if ($category) {
    $parentIds = array_slice(explode('/', $category->getPath()), 2, -1);
    foreach ($parentIds as $parentId) {
        $parent = $category->load($parentId);
        if ($parent->getId() && $parent->getIsActive()) {
            $breadcrumbs[] = [
                'name' => $escaper->escapeHtml($parent->getName()),
                'url'  => $escaper->escapeUrl($parent->getUrl()),
            ];
        }
    }
}
?>

<!-- =================== BREADCRUMB =================== -->
<nav class="bg-paper border-b border-line" aria-label="<?= $escaper->escapeHtmlAttr(__('Breadcrumb')) ?>">
    <div class="max-w-8xl mx-auto px-4 lg:px-8 py-3">
        <ol class="flex items-center flex-wrap gap-1.5 text-sm">
            <li>
                <a href="<?= $escaper->escapeUrl($block->getBaseUrl()) ?>"
                   class="text-stone hover:text-accent transition">
                    <?= $escaper->escapeHtml(__('Home')) ?>
                </a>
            </li>

            <?php foreach ($breadcrumbs as $crumb): ?>
